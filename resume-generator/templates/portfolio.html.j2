{#- Portfolio template - rendered from data.json via Jinja2 -#}
{%- set gh = data.personal.github -%}
{%- set fname = data.personal.name | replace(" ", "_") -%}
{%- set resume_base = "https://github.com/" ~ gh ~ "/" ~ gh ~ "/raw/main/output/" -%}
{%- set portfolio_skill_cats = data.skills_by_resume.backend_crypto -%}
{%- set commit_hashes = ['a3f7c1e','b8e2d4a','c5a1f9b','d2c8e7f','e1f0a8c','f3d2b1a','a7b8c9d','d0e1f2a'] -%}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ data.meta.title }}</title>
<meta name="description" content="{{ data.meta.description }}">
<meta name="theme-color" content="#F59E0B">
<meta property="og:title" content="{{ data.seo.title }}">
<meta property="og:description" content="{{ data.seo.description }}">
<meta property="og:type" content="website">
<meta property="og:url" content="{{ data.seo.json_ld.url }}">
<meta property="og:image" content="{{ data.seo.og_image }}">
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "{{ data.seo.json_ld.name }}",
  "jobTitle": "{{ data.seo.json_ld.jobTitle }}",
  "url": "{{ data.seo.json_ld.url }}",
  "knowsAbout": [{% for item in data.seo.json_ld.knowsAbout %}"{{ item }}"{% if not loop.last %}, {% endif %}{% endfor %}],
  "sameAs": [
    {% for url in data.seo.json_ld.sameAs %}"{{ url }}"{% if not loop.last %},
    {% endif %}{% endfor %}
  ]
}
</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#050508;--bg-card:#0a0a10;--bg-hover:rgba(245,158,11,0.03);
  --border:#111118;--border-accent:#1a1a2e;
  --text:#e5e5e5;--text-dim:#888;--text-muted:#555;--text-faint:#333;
  --amber:#F59E0B;--cyan:#06B6D4;--green:#4ADE80;--red:#F87171;--purple:#A78BFA;
  --mono:'JetBrains Mono','Fira Code',monospace;
  --sans:'IBM Plex Sans','Inter',-apple-system,sans-serif;
}
html{scroll-behavior:smooth;scrollbar-width:thin;scrollbar-color:#1a1a2e #050508}
body{font-family:var(--mono);background:var(--bg);color:var(--text);line-height:1.6;overflow-x:hidden}
::selection{background:rgba(245,158,11,0.2);color:#fff}
.container{max-width:800px;margin:0 auto;padding:0 24px;position:relative;z-index:10}
section{padding:48px 0;border-top:1px solid var(--border)}
section:first-of-type{border-top:none}
.glow-tr{position:fixed;top:-200px;right:-200px;width:600px;height:600px;background:radial-gradient(circle,rgba(245,158,11,0.04) 0%,transparent 70%);pointer-events:none;z-index:0}

/* Nav */
nav{position:fixed;top:0;left:0;right:0;padding:12px 24px;background:rgba(5,5,8,0.92);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);z-index:1000;display:flex;justify-content:space-between;align-items:center}
.nav-logo{font-size:13px;color:var(--green)}.nav-logo .s{color:var(--text-muted)}
.nav-links{display:flex;gap:20px;align-items:center}
.nav-links a{color:var(--text-muted);font-size:12px;text-decoration:none;transition:color .2s;letter-spacing:.5px}
.nav-links a:hover{color:var(--amber)}
.terminal-toggle{font-size:11px;color:var(--green);background:rgba(74,222,128,0.08);border:1px solid rgba(74,222,128,0.2);border-radius:4px;padding:4px 10px;cursor:pointer;transition:all .2s;font-family:var(--mono)}
.terminal-toggle:hover{background:rgba(74,222,128,0.15);border-color:rgba(74,222,128,0.4)}
@media(max-width:640px){.nav-links a:not(.terminal-toggle-wrap){display:none}}

/* Hero */
header.hero{padding:100px 0 48px}
.hero-label{font-size:11px;color:var(--text-muted);letter-spacing:2px;margin-bottom:12px;text-transform:uppercase}
.hero h1{font-size:clamp(28px,6vw,40px);font-weight:700;color:var(--amber);letter-spacing:-1px;line-height:1.2;font-family:var(--sans);margin:0}
.hero-subtitle{color:var(--text-dim);font-size:14px;margin-top:8px;line-height:1.6;max-width:620px;font-family:var(--sans)}
.hero-tagline{color:var(--text-muted);font-size:12px;margin-top:4px}

/* Contact pills */
.contact-row{display:flex;gap:10px;margin-top:20px;flex-wrap:wrap}
.contact-pill{font-size:12px;color:var(--cyan);text-decoration:none;padding:4px 12px;border:1px solid rgba(6,182,212,0.2);border-radius:4px;transition:all .2s;font-family:var(--mono)}
.contact-pill:hover{background:rgba(6,182,212,0.08);border-color:rgba(6,182,212,0.4)}

/* Resume buttons */
.resume-row{display:flex;gap:8px;margin-top:14px;flex-wrap:wrap}
.resume-btn{font-size:11px;color:var(--purple);text-decoration:none;padding:5px 14px;border:1px solid rgba(167,139,250,0.25);border-radius:4px;transition:all .2s;font-weight:500;font-family:var(--mono)}
.resume-btn:hover{background:rgba(167,139,250,0.1);border-color:rgba(167,139,250,0.5)}

/* Metrics */
.metrics-bar{display:grid;grid-template-columns:repeat(auto-fit,minmax(110px,1fr));gap:12px;margin-top:28px;padding:16px;background:var(--bg-hover);border:1px solid var(--border);border-radius:6px}
.metric-item{text-align:center}
.metric-val{font-size:22px;font-weight:700;color:var(--amber);font-family:var(--sans)}
.metric-label{font-size:10px;color:var(--text-muted);margin-top:2px;letter-spacing:.5px}

/* Sections */
.section-cmd{font-size:11px;color:var(--text-muted);letter-spacing:2px;margin-bottom:6px;font-family:var(--mono)}
.section-title{font-size:20px;font-weight:600;color:var(--text);margin:0 0 24px;font-family:var(--sans)}

/* Git log experience */
.commit{padding:14px 20px;margin-bottom:2px;cursor:pointer;position:relative;border-left:2px solid var(--border-accent);transition:background .2s}
.commit:hover{background:var(--bg-hover)}
.commit.hl{border-left-color:var(--amber);background:rgba(245,158,11,0.02)}
.commit.exp{background:rgba(245,158,11,0.04)}
.commit-dot{position:absolute;left:-6px;top:20px;width:10px;height:10px;border-radius:50%;background:var(--text-faint);border:2px solid var(--text-muted)}
.commit.hl .commit-dot{background:var(--amber);border-color:var(--amber);box-shadow:0 0 12px rgba(245,158,11,0.4)}
.commit-header{display:flex;align-items:baseline;flex-wrap:wrap;gap:8px}
.ch{color:var(--amber);font-size:13px}
.cd{color:var(--text-dim);font-size:12px}
.cm{color:var(--text);font-weight:600;font-size:13px;margin-left:4px}
.cc{color:var(--text-dim);font-size:12px;font-weight:400;margin-top:2px}
.commit-hint{position:absolute;right:16px;top:18px;font-size:10px;color:var(--text-faint);transition:opacity .2s}
.commit.exp .commit-hint{opacity:0}
.tag-row{display:flex;gap:6px;margin-top:8px;flex-wrap:wrap}
.tag{font-size:10px;padding:2px 8px;border-radius:3px;background:rgba(6,182,212,0.08);color:var(--cyan);border:1px solid rgba(6,182,212,0.15)}
.commit-details{max-height:0;overflow:hidden;transition:max-height .5s ease}
.commit.exp .commit-details{max-height:1000px}
.commit-body{padding-top:12px}
.cb-list{list-style:none;padding:0;margin:0}
.cb-list li{font-size:13px;color:var(--text-dim);line-height:1.7;padding:3px 0 3px 18px;position:relative}
.cb-list li::before{content:'\203A';position:absolute;left:0;color:var(--amber);font-weight:700}

/* Skills */
.skill-cats{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px}
.skill-cat h4{font-size:12px;color:var(--amber);font-weight:500;margin-bottom:8px;letter-spacing:.5px;font-family:var(--sans)}
.sct{display:flex;flex-wrap:wrap;gap:4px}
.sctag{font-size:10px;padding:3px 8px;border-radius:3px;background:rgba(245,158,11,0.05);color:var(--text-dim);border:1px solid var(--border)}

/* Projects */
.pg{display:grid;gap:12px}
.pc{padding:16px;border:1px solid var(--border);border-radius:6px;transition:all .3s}
.pc:hover{border-color:rgba(245,158,11,0.2);background:var(--bg-hover)}
.pt{font-size:14px;font-weight:600;color:var(--text);margin-bottom:6px;font-family:var(--sans)}
.pd{font-size:12px;color:var(--text-dim);margin-bottom:10px;line-height:1.6}
.pm{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:10px}
.pmv{font-size:16px;font-weight:700;color:var(--amber);font-family:var(--sans)}
.pml{font-size:9px;color:var(--text-muted);letter-spacing:.5px}
.pl{display:flex;gap:8px;margin-top:10px}
.pl a{font-size:11px;padding:4px 10px;border-radius:4px;text-decoration:none;border:1px solid var(--border);color:var(--text-dim);transition:all .2s;font-family:var(--mono);letter-spacing:.3px}
.pl a:hover{border-color:var(--amber);color:var(--amber)}

/* Education */
.edu{display:flex;align-items:center;gap:10px;padding:8px 0;font-size:12px}
.edu-ck{color:var(--green)}.edu-n{color:var(--text);font-weight:500}.edu-s{color:var(--text-muted)}.edu-o{color:var(--text-dim)}.edu-y{color:var(--text-muted);margin-left:auto}
.lang-row{display:flex;gap:20px;font-size:12px;color:var(--text-dim);margin-top:16px}
.lang-k{color:var(--text-muted)}.lang-v{color:var(--text)}

/* Footer */
footer{padding:40px 0 60px;border-top:1px solid var(--border);text-align:center}
.fn{font-size:11px;color:var(--text-faint);margin-top:8px}
.fn a{color:var(--text-muted);text-decoration:none}

/* Reveal animations */
.rv{opacity:0;transform:translateY(12px);transition:opacity .5s,transform .5s}
.rv.vis{opacity:1;transform:translateY(0)}

/* Terminal mode */
#terminal-mode{display:none;background:#000;color:#4ADE80;font-family:var(--mono);font-size:14px;min-height:100vh;padding:60px 24px 24px}
#terminal-mode.active{display:block}
#normal-mode.hidden{display:none}
.term-output{white-space:pre-wrap;line-height:1.7;max-width:800px;margin:0 auto}
.term-input-line{display:flex;align-items:center;gap:8px;max-width:800px;margin:0 auto;margin-top:4px}
.term-prompt{color:#4ADE80;white-space:nowrap}
.term-input{background:transparent;border:none;color:#4ADE80;font-family:var(--mono);font-size:14px;outline:none;flex:1;caret-color:#4ADE80}
.term-cursor{display:inline-block;width:8px;height:16px;background:#4ADE80;animation:blink 1s step-end infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
.term-welcome{color:var(--text-muted);margin-bottom:16px}
</style>
<!-- Yandex.Metrika counter -->
<script type="text/javascript">
    (function(m,e,t,r,i,k,a){
        m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
        m[i].l=1*new Date();
        for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
        k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
    })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id={{ data.analytics.yandex_metrika_id }}', 'ym');
    ym({{ data.analytics.yandex_metrika_id }}, 'init', {
        clickmap: true,
        trackLinks: true,
        accurateTrackBounce: true,
        webvisor: true,
        trackHash: true
    });
</script>
<noscript><div><img src="https://mc.yandex.ru/watch/{{ data.analytics.yandex_metrika_id }}" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
<!-- /Yandex.Metrika counter -->
</head>
<body>
<div class="glow-tr"></div>

<nav>
  <div class="nav-logo">~/{{ data.personal.github | lower }}<span class="s">/portfolio</span></div>
  <div class="nav-links">
    <a href="#experience">experience</a>
    <a href="#skills">skills</a>
    <a href="#projects">projects</a>
    <a href="#contact">contact</a>
    <button class="terminal-toggle" id="mode-toggle" onclick="toggleMode()">Terminal Mode</button>
  </div>
</nav>

<!-- ==================== NORMAL MODE ==================== -->
<div id="normal-mode">
<div class="container">

<header class="hero">
  <div class="hero-label">{{ data.titles.portfolio }}</div>
  <h1>{{ data.personal.name }}</h1>
  <p class="hero-subtitle">{{ data.personal.tagline }}</p>
  <p class="hero-tagline">{{ data.personal.open_to }}</p>

  <div class="contact-row">
    <a class="contact-pill" href="https://github.com/{{ data.personal.github }}">GitHub</a>
    <a class="contact-pill" href="https://linkedin.com/in/{{ data.personal.linkedin }}">LinkedIn</a>
    <a class="contact-pill" href="https://t.me/{{ data.personal.telegram }}">Telegram</a>
    <a class="contact-pill" href="mailto:{{ data.personal.email }}">Email</a>
  </div>

  <div class="resume-row">
    <a class="resume-btn" href="{{ resume_base }}{{ fname }}_Resume_Backend_Crypto.pdf" download>Backend (Crypto)</a>
    <a class="resume-btn" href="{{ resume_base }}{{ fname }}_Resume_Backend.pdf" download>Backend</a>
    <a class="resume-btn" href="{{ resume_base }}{{ fname }}_Resume_TechLead_Crypto.pdf" download>Tech Lead (Crypto)</a>
    <a class="resume-btn" href="{{ resume_base }}{{ fname }}_Resume_TechLead.pdf" download>Tech Lead</a>
    <a class="resume-btn" href="{{ resume_base }}{{ fname }}_Resume_CTO.pdf" download>CTO</a>
  </div>

  <div class="metrics-bar">
    {% for stat in data.stats %}
    <div class="metric-item"><div class="metric-val">{{ stat.value }}{{ stat.suffix }}</div><div class="metric-label">{{ stat.label }}</div></div>
    {% endfor %}
  </div>
</header>

<!-- Experience -->
<section id="experience">
  <div class="section-cmd">$ git log --career --oneline --stat</div>
  <h2 class="section-title">Work Experience</h2>

  {% for job in data.experience %}
  <article class="commit{% if loop.first %} hl{% endif %}" onclick="this.classList.toggle('exp')">
    <div class="commit-dot"></div>
    <div class="commit-header">
      <span class="ch">{{ commit_hashes[loop.index0 % commit_hashes|length] }}</span>
      <span class="cd">{{ job.period }}</span>
      <span class="cm">{{ job.titles.portfolio }}</span>
    </div>
    <div class="cc">{{ job.company }}{% if job.product is string %} &mdash; {{ job.product }}{% endif %}{% if job.location %} &middot; {{ job.location }}{% endif %}</div>
    <div class="commit-hint">expand</div>
    <div class="commit-details"><div class="commit-body">
      <ul class="cb-list">
        {% for bullet in job.bullets %}
        {% if 'backend_crypto' in bullet.resumes or 'techlead_crypto' in bullet.resumes %}
        <li>{{ bullet.text }}</li>
        {% endif %}
        {% endfor %}
      </ul>
      <div class="tag-row">
        {% if job.tech is mapping %}
          {% for tech in job.tech.crypto %}
        <span class="tag">{{ tech }}</span>
          {%- endfor %}
        {% else %}
          {% for tech in job.tech %}
        <span class="tag">{{ tech }}</span>
          {%- endfor %}
        {% endif %}
      </div>
    </div></div>
  </article>
  {% endfor %}
</section>

<!-- Skills -->
<section id="skills">
  <div class="section-cmd">$ cat /etc/skills.d/*</div>
  <h2 class="section-title">Technical Skills</h2>
  <div class="skill-cats">
    {% for cat_key in portfolio_skill_cats %}
    {% set cat = data.skills[cat_key] %}
    <div class="skill-cat rv">
      <h4>{{ cat.label }}</h4>
      <div class="sct">
        {% for item in cat['items'] %}
        <span class="sctag">{{ item }}</span>
        {%- endfor %}
      </div>
    </div>
    {% endfor %}
  </div>
</section>

<!-- Projects -->
<section id="projects">
  <div class="section-cmd">$ ls ~/projects --featured</div>
  <h2 class="section-title">Featured Projects</h2>
  <div class="pg">
    {% for project in data.projects %}
    {% if project.featured %}
    <div class="pc rv">
      <div class="pt">{{ project.title }}</div>
      <div class="pd">{{ project.description }}</div>
      {% if project.metrics is defined %}
      <div class="pm">
        {% for metric in project.metrics %}
        <div><div class="pmv">{{ metric.value }}</div><div class="pml">{{ metric.label }}</div></div>
        {% endfor %}
      </div>
      {% endif %}
      <div class="tag-row">
        {% if project.tech is mapping %}
          {% for tech in project.tech.crypto %}
        <span class="tag">{{ tech }}</span>
          {%- endfor %}
        {% else %}
          {% for tech in project.tech %}
        <span class="tag">{{ tech }}</span>
          {%- endfor %}
        {% endif %}
      </div>
      {% if project.github_url is defined or project.docs_url is defined %}
      <div class="pl">
        {% if project.github_url is defined %}<a href="{{ project.github_url }}" target="_blank" rel="noopener">GitHub</a>{% endif %}
        {% if project.docs_url is defined %}<a href="{{ project.docs_url }}" target="_blank" rel="noopener">Docs</a>{% endif %}
      </div>
      {% endif %}
    </div>
    {% endif %}
    {% endfor %}
  </div>
</section>

<!-- Education -->
<section id="education">
  <div class="section-cmd">$ cat /etc/certs.d/*</div>
  <h2 class="section-title">Professional Development</h2>
  {% for edu in data.education %}
  <div class="edu rv"><span class="edu-ck">&#10003;</span><span class="edu-n">{{ edu.title }}</span><span class="edu-s">&mdash;</span><span class="edu-o">{{ edu.institution }}</span><span class="edu-y">{{ edu.status }}</span></div>
  {% endfor %}
  <div style="margin-top:20px">
    <div class="section-cmd">$ locale</div>
    <div class="lang-row">
      {% for lang, level in data.languages.items() %}
      <div><span class="lang-k">{{ lang | capitalize }}:</span> <span class="lang-v">{{ level }}</span></div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Contact -->
<section id="contact">
  <div class="section-cmd">$ echo $CONTACT_INFO</div>
  <h2 class="section-title">Let's Connect</h2>
  <p style="color:var(--text-dim);font-size:13px;line-height:1.7;max-width:500px;margin-bottom:20px;font-family:var(--sans)">{{ data.linkedin.cta }}</p>
  <div class="contact-row">
    <a class="contact-pill" href="mailto:{{ data.personal.email }}">Email</a>
    <a class="contact-pill" href="https://t.me/{{ data.personal.telegram }}">Telegram</a>
    <a class="contact-pill" href="https://linkedin.com/in/{{ data.personal.linkedin }}">LinkedIn</a>
    <a class="contact-pill" href="https://github.com/{{ data.personal.github }}">GitHub</a>
  </div>
</section>

<footer>
  <div class="fn">Rendered from <a href="https://github.com/{{ data.personal.github }}/{{ data.personal.github }}">data.json</a></div>
</footer>

</div>
</div>

<!-- ==================== TERMINAL MODE ==================== -->
<div id="terminal-mode">
  <div class="term-output" id="term-output">
    <div class="term-welcome">{{ data.personal.name }} | {{ data.titles.portfolio }}
Type "help" for available commands.
</div>
  </div>
  <div class="term-input-line">
    <span class="term-prompt">{{ data.personal.telegram }}@portfolio:~$</span>
    <input class="term-input" id="term-input" type="text" autocomplete="off" autofocus spellcheck="false">
  </div>
</div>

<script>
(function(){
  // Mode toggle
  window.toggleMode = function(){
    var nm = document.getElementById('normal-mode');
    var tm = document.getElementById('terminal-mode');
    var btn = document.getElementById('mode-toggle');
    if(tm.classList.contains('active')){
      tm.classList.remove('active');
      nm.classList.remove('hidden');
      btn.textContent = 'Terminal Mode';
    } else {
      tm.classList.add('active');
      nm.classList.add('hidden');
      btn.textContent = 'Normal Mode';
      document.getElementById('term-input').focus();
    }
  };

  // Reveal animations
  var ro = new IntersectionObserver(function(es){
    es.forEach(function(e){if(e.isIntersecting) e.target.classList.add('vis')});
  },{threshold:0.15});
  document.querySelectorAll('.rv').forEach(function(el){ro.observe(el)});

  // Staggered commit animations
  document.querySelectorAll('.commit').forEach(function(c,i){
    c.style.opacity='0';c.style.transform='translateX(-16px)';
    c.style.transition='opacity .5s ease '+i*0.1+'s,transform .5s ease '+i*0.1+'s,background .2s';
    var co = new IntersectionObserver(function(es){
      es.forEach(function(e){
        if(e.isIntersecting){e.target.style.opacity='1';e.target.style.transform='translateX(0)';co.unobserve(e.target)}
      });
    },{threshold:0.1});
    co.observe(c);
  });

  // Terminal
  var output = document.getElementById('term-output');
  var input = document.getElementById('term-input');
  var gh = '{{ data.personal.github }}';
  var base = 'https://github.com/'+gh+'/'+gh+'/raw/main/output/';

  var commands = {
    help: function(){
      return 'Available commands:\n  about       - Summary\n  experience  - Work history\n  skills      - Technical skills\n  projects    - Featured projects\n  contact     - Contact information\n  resume TYPE - Download resume (backend-crypto, backend, techlead-crypto, techlead, cto)\n  clear       - Clear screen\n  exit        - Switch to normal mode';
    },
    about: function(){
      return '{{ data.personal.name | replace("'", "\\'") }}\n{{ data.titles.portfolio | replace("'", "\\'") }}\n\n{{ data.summaries.portfolio | replace("'", "\\'") }}';
    },
    experience: function(){
      return 'Work Experience\n' +
{% for job in data.experience %}
        '\n[{{ job.period }}] {{ job.titles.portfolio | replace("'", "\\'") }} @ {{ job.company | replace("'", "\\'") }}' +
        '\n  {{ (job.product if job.product is string else "") | replace("'", "\\'") }}{% if job.location %}. {{ job.location | replace("'", "\\'") }}{% endif %}' +
{% endfor %}
        '';
    },
    skills: function(){
      return 'Technical Skills\n' +
{% for cat_key in portfolio_skill_cats %}
        '\n{{ data.skills[cat_key].label | replace("'", "\\'") }}: {{ data.skills[cat_key]["items"] | join(", ") | replace("'", "\\'") }}' +
{% endfor %}
        '';
    },
    projects: function(){
      return 'Featured Projects\n' +
{% for project in data.projects %}
{% if project.featured %}
        '\n{{ loop.index }}. {{ project.title | replace("'", "\\'") }}\n   {{ project.description | replace("'", "\\'") }}' +
        '\n   [{{ (project.tech | join(", ") if project.tech is not mapping else project.tech.crypto | join(", ")) | replace("'", "\\'") }}]' +
{% endif %}
{% endfor %}
        '';
    },
    contact: function(){
      return 'Contact\n\n  Email:    {{ data.personal.email | replace("'", "\\'") }}\n  Telegram: t.me/{{ data.personal.telegram | replace("'", "\\'") }}\n  LinkedIn: linkedin.com/in/{{ data.personal.linkedin | replace("'", "\\'") }}\n  GitHub:   github.com/{{ data.personal.github | replace("'", "\\'") }}\n\n{{ data.personal.open_to | replace("'", "\\'") }}';
    },
    clear: function(){output.innerHTML='';return null},
    exit: function(){window.toggleMode();return null}
  };

  var resumeMap = {
    'backend-crypto': '{{ fname }}_Resume_Backend_Crypto.pdf',
    'backend': '{{ fname }}_Resume_Backend.pdf',
    'techlead-crypto': '{{ fname }}_Resume_TechLead_Crypto.pdf',
    'techlead': '{{ fname }}_Resume_TechLead.pdf',
    'cto': '{{ fname }}_Resume_CTO.pdf'
  };

  function processCommand(cmd){
    cmd = cmd.trim().toLowerCase();
    if(!cmd) return '';
    if(cmd.startsWith('resume ')){
      var type = cmd.slice(7).trim();
      if(resumeMap[type]){
        var a = document.createElement('a');
        a.href = base + resumeMap[type];
        a.download = resumeMap[type];
        a.click();
        return 'Downloading ' + resumeMap[type] + '...';
      }
      return 'Unknown resume type. Available: backend-crypto, backend, techlead-crypto, techlead, cto';
    }
    if(commands[cmd]) return commands[cmd]();
    return 'Command not found: ' + cmd + '. Type "help" for available commands.';
  }

  if(input){
    input.addEventListener('keydown', function(e){
      if(e.key === 'Enter'){
        var cmd = input.value;
        var line = document.createElement('div');
        line.innerHTML = '<span style="color:#4ADE80">{{ data.personal.telegram }}@portfolio:~$</span> ' + cmd;
        output.appendChild(line);
        var result = processCommand(cmd);
        if(result !== null && result !== undefined){
          var out = document.createElement('div');
          out.style.whiteSpace = 'pre-wrap';
          out.style.marginBottom = '8px';
          out.textContent = result;
          output.appendChild(out);
        }
        input.value = '';
        output.scrollTop = output.scrollHeight;
      }
    });
  }

  // Click terminal area to focus input
  document.getElementById('terminal-mode').addEventListener('click', function(){
    document.getElementById('term-input').focus();
  });
})();
</script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  var YM_ID = {{ data.analytics.yandex_metrika_id }};

  document.querySelectorAll('.resume-btn, a[download]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      ym(YM_ID, 'reachGoal', 'resume_download', {
        type: this.textContent.trim(),
        href: this.getAttribute('href')
      });
    });
  });

  var contactLinks = {
    'github.com': 'click_github',
    'linkedin.com': 'click_linkedin',
    't.me': 'click_telegram',
    'mailto:': 'click_email'
  };
  Object.keys(contactLinks).forEach(function(domain) {
    document.querySelectorAll('a[href*="' + domain + '"]').forEach(function(link) {
      link.addEventListener('click', function() {
        ym(YM_ID, 'reachGoal', contactLinks[domain]);
      });
    });
  });

  var fired50 = false, fired90 = false;
  window.addEventListener('scroll', function() {
    var pct = (window.scrollY + window.innerHeight) / document.documentElement.scrollHeight * 100;
    if (pct >= 50 && !fired50) { ym(YM_ID, 'reachGoal', 'scroll_50'); fired50 = true; }
    if (pct >= 90 && !fired90) { ym(YM_ID, 'reachGoal', 'scroll_90'); fired90 = true; }
  });

  setTimeout(function() { ym(YM_ID, 'reachGoal', 'engaged_60s'); }, 60000);

  var termToggle = document.querySelector('.terminal-toggle');
  if (termToggle) {
    termToggle.addEventListener('click', function() {
      ym(YM_ID, 'reachGoal', 'toggle_terminal');
    });
  }
});
</script>
</body>
</html>
